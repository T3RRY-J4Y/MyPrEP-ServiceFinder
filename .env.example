# ── Copy this file to .env and fill in your Firebase values ─────────────────
#
# In GitHub Codespaces:
#   Option A (recommended): Add these as Codespaces Secrets at
#     github.com → Settings → Codespaces → Secrets
#     They will be available automatically as environment variables.
#
#   Option B: Copy this file to .env and fill in values manually.
#     The .env file is gitignored and will NOT be committed.
#
# NEVER commit your actual .env file to git.
# ────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# From Firebase Console → App Check → reCAPTCHA v3
# Leave blank to skip App Check (not recommended for production)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
